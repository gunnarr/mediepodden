# Site-wide basic auth (leave empty to disable)
SITE_USERNAME=
SITE_PASSWORD=

# Admin authentication (for /admin)
ADMIN_PASSWORD=

# Database and audio
DATABASE_PATH=data/mediepodden.db
AUDIO_DIR=data/audio
SITE_DOMAIN=localhost:8000

# Speaker diarization (optional, requires HuggingFace token)
HUGGINGFACE_TOKEN=

# MLX Whisper model path (for local Apple Silicon transcription)
# MLX_WHISPER_MODEL=cache/kb-whisper-large-mlx

# S3 audio storage (leave bucket empty to use only local files)
S3_AUDIO_BUCKET=
S3_AUDIO_REGION=eu-north-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Entity extraction (Claude API)
# ANTHROPIC_API_KEY=

# Hour (0-23) to check RSS feed for new episodes
FEED_CHECK_HOUR=3
